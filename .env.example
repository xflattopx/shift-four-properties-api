PORT=3000
FRONTEND_ORIGIN=http://localhost:5500

# SMTP provider settings (Mailgun, SendGrid SMTP relay, Gmail app password, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Lead delivery
LEAD_FROM_EMAIL=leads@yourdomain.com
LEAD_TO_EMAIL=you@yourdomain.com
LEAD_REPLY_TO=you@yourdomain.com
